# ============================================
# 辅导员智能助手系统 - 环境配置文件
# ============================================

# ============================================
# LLM 配置 - 选择一种即可
# ============================================

# LLM 提供商选择: ollama, llamacpp, openai, dashscope, ernie, moonshot
# 推荐使用 ollama (本地部署，免费)
LLM_PROVIDER=ollama

# 模型名称
# Ollama: qwen2:7b, qwen2:14b, qwen2:72b, llama3.1:8b, deepseek-v3:8b
# OpenAI: gpt-4-turbo, gpt-3.5-turbo
# 通义千问: qwen-max, qwen-plus, qwen-turbo
LLM_MODEL=qwen2:7b

# 温度参数 (0-1)，越低越确定，越高越有创造性
LLM_TEMPERATURE=0.7

# 最大生成 token 数
LLM_MAX_TOKENS=2048

# 是否流式输出
LLM_STREAM=false

# 超时时间(秒)
LLM_TIMEOUT=60

# ============================================
# Ollama 配置 (推荐)
# ============================================
# Ollama API 地址，默认本地
OLLAMA_API_BASE=http://localhost:11434

# ============================================
# llama.cpp 配置 (可选)
# ============================================
# llama.cpp API 地址
LLAMACPP_API_BASE=http://localhost:8080

# ============================================
# OpenAI 配置 (可选，需付费)
# ============================================
# 你的 OpenAI API Key
OPENAI_API_KEY=your-openai-api-key-here
# 代理地址（如果需要）
OPENAI_API_BASE=https://api.openai.com/v1

# ============================================
# 通义千问配置 (可选，需付费)
# ============================================
DASHSCOPE_API_KEY=your-dashscope-api-key-here

# ============================================
# Kimi / Moonshot 配置 (可选，需付费)
# ============================================
MOONSHOT_API_KEY=your-moonshot-api-key-here

# ============================================
# 数据库配置
# ============================================
# 数据库用户名
DB_USER=root
# 数据库密码
DB_PASSWORD=123456
# 数据库地址
DB_HOST=127.0.0.1
# 数据库端口
DB_PORT=3306
# 数据库名称
DB_NAME=counselor_agent

# ============================================
# Redis 配置 (可选，用于缓存)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================
# 后端服务配置
# ============================================
# 后端监听地址
BACKEND_HOST=0.0.0.0
# 后端监听端口
BACKEND_PORT=8000
# 是否开启调试模式
DEBUG=true

# ============================================
# 前端服务配置
# ============================================
# 前端地址（CORS配置用）
FRONTEND_URL=http://localhost:3000
